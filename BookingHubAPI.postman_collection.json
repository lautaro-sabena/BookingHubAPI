{
  "info": {
    "name": "BookingHubAPI",
    "description": "Multi-tenant SaaS booking system API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"Test1234!\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"role\": \"Customer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"Test1234!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Get My Company",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/companies/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/companies",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Business\",\n  \"description\": \"A sample business\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main St\"\n}"
            }
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/companies/me",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Business\",\n  \"description\": \"Updated description\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main St\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Get Services by Company",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/services",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/services",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Haircut\",\n  \"description\": \"Standard haircut\",\n  \"duration\": 30,\n  \"price\": 25.00\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Get All Reservations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reservations",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/reservations",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"customerId\": \"{{userId}}\",\n  \"date\": \"2026-03-15T10:00:00Z\",\n  \"notes\": \"Test reservation\"\n}"
            }
          }
        },
        {
          "name": "Cancel Reservation",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/reservations/{{reservationId}}/cancel",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Availability",
      "item": [
        {
          "name": "Get Available Slots",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/availability/{{serviceId}}?date=2026-03-15",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "availability",
                "{{serviceId}}"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-03-15"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}
