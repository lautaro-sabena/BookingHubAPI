# Connection String para la base de datos SQL Server
DB_CONNECTION_STRING=Server=localhost;Database=BookingHubDB;User Id=sa;Password=TU_PASSWORD_AQUI;TrustServerCertificate=True

# Clave secreta para JWT (mínimo 32 caracteres, usar una clave segura)
JWT_SECRET_KEY=TU_CLAVE_SECRETA_MINIMO_32_CARACTERES_AQUI

# Orígenes permitidos para CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://tudominio.com
