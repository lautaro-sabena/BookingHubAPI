{
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "GeneralRule": {
      "Endpoint": "*",
      "Period": "1m",
      "Limit": 60
    },
    "Rules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "5m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "1h",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/api/reservations",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/reservations",
        "Period": "1m",
        "Limit": 30
      }
    ]
  }
}
